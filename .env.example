# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=your-super-secret-session-key-change-this

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=finance_tracker

# Google OAuth (optional - app works without it)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# SendGrid (optional - falls back to console logging)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourfinancetracker.com

# OpenAI (optional - for LLM features)
OPENAI_API_KEY=your-openai-api-key

# Exchange Rate API (optional - uses free tier without key)
EXCHANGE_RATE_API_KEY=
